      "Write(__tests__/**)",
      "Write(spec/**)",
      "Write(packages/**)",
      "Write(docs/**)",
      "Write(tasks/**)",
      "Write(.claude/memory/**)",
      "Write(.claude/audit/**)",
      "Write(.claude/task-context.md)",
      "Write(*.ts)",
      "Write(*.tsx)",
      "Write(*.js)",
      "Write(*.jsx)",
      "Write(*.py)",
