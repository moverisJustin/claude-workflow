  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hook-session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {
          "tool": ["Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.js|*.ts|*.jsx|*.tsx|*.json|*.css|*.scss|*.md) npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true ;; esac"
          }
        ]
      },
      {
        "matcher": {
          "tool": ["Bash"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hook-branch-switch.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": {
          "tool": ["Bash"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/audit && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) BASH $CLAUDE_TOOL_INPUT\" >> .claude/audit/commands.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": {
          "tool": ["Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/audit && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) FILE_WRITE $CLAUDE_FILE_PATH\" >> .claude/audit/files.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": {
          "tool": ["Bash"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hook-destructive-guard.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_BORIS_VERSION": "2.0.0",
    "BORIS_MEMORY_BANK": "true",
    "BORIS_AUDIT_LOG": "true"
  }
}
