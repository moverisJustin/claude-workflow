{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm audit*)",
      "Bash(npm outdated*)",
      "Bash(npm ci*)",
      "Bash(npm exec*)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(deno *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(date *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(jq *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(diff *)",
      "Bash(sha256sum *)",
      "Bash(md5sum *)",
      "Bash(base64 *)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(docker-compose *)",
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pytest *)",
      "Bash(ruby *)",
      "Bash(bundle *)",
      "Bash(rails *)",
      "Bash(rspec *)",
      "Bash(fly *)",
      "Bash(ssh *)",
      "Bash(rclone *)",
      "Bash(brew *)",
      "Bash(.venv/bin/*)",
      "Bash(xxd *)",
      "Bash(command -v *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo rm *)",
      "Bash(sudo dd *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/*)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool": ["Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.js|*.ts|*.jsx|*.tsx|*.json|*.css|*.scss|*.md) npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": {
          "tool": ["Bash"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/audit && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) BASH $CLAUDE_TOOL_INPUT\" >> .claude/audit/commands.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": {
          "tool": ["Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/audit && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) FILE_WRITE $CLAUDE_FILE_PATH\" >> .claude/audit/files.log 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_BORIS_VERSION": "2.0.0",
    "BORIS_MEMORY_BANK": "true",
    "BORIS_AUDIT_LOG": "true"
  }
}
